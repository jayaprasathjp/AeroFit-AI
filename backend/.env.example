# Copy to .env and fill in.

# --- LLM provider ----------------------------------------------------------
# "vertexai" (default) -> Google Cloud Vertex AI, no API key.
# "google"             -> Google AI Studio (API key).
LLM_PROVIDER=vertexai
GEMINI_MODEL=gemini-2.0-flash

# --- Vertex AI (LLM_PROVIDER=vertexai) -------------------------------------
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Authenticate with EITHER:
#   1) A service-account JSON key (no gcloud CLI needed) — recommended:
SERVICE_ACCOUNT_FILE=/path/to/service-account.json
#   2) gcloud CLI: run `gcloud auth application-default login` and leave the
#      service-account line above unset.

# --- Google AI Studio (LLM_PROVIDER=google) --------------------------------
# Get a free API key at https://aistudio.google.com/apikey
# GOOGLE_API_KEY=your-gemini-api-key
